# -----------------------------------
# Application Settings
# -----------------------------------
APP_NAME=AI Posture Analysis Service
VERSION=1.0.0

# -----------------------------------
# CORS Configuration
# -----------------------------------
ALLOWED_ORIGINS=["*"]

# -----------------------------------
# Video Duration Constraints (seconds)
# -----------------------------------
MIN_VIDEO_DURATION=10
MAX_VIDEO_DURATION=15

# -----------------------------------
# Frame Sampling
# -----------------------------------
FRAME_SAMPLING_RATE=5

# -----------------------------------
# Storage Paths
# -----------------------------------
STORAGE_ROOT=storage
TEMP_FOLDER=storage/temp
IMAGE_FOLDER=storage/images
REPORT_FOLDER=storage/reports